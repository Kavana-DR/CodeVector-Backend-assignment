generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://postgres.nhadgpmmvgkxuhbkuhaq:CodeVector@2026DB!@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id         BigInt   @id @default(autoincrement())
  name       String
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "products_created_at_id_idx")
  @@index([categoryId, createdAt(sort: Desc), id(sort: Desc)], map: "products_category_created_at_id_idx")
  @@map("products")
}
