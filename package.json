{
  "name": "product-catalog-api",
  "version": "1.0.0",
  "private": true,
  "description": "Cursor-paginated product catalog API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "dotenv": "16.6.1",
    "express": "5.1.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "24.10.1",
    "prisma": "6.19.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
